generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum AiAnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  IGNORED
  APPROVED
}

enum LeadStatus {
  NEW
  REVIEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  REJECTED
  ARCHIVED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AuditSource {
  MANUAL
  AUTOMATION
  API
  COLLECTOR
  EMAIL_SYNC
  AI
  SYSTEM
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  DEAD
}

model Workspace {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  slug            String           @unique
  timezone        String           @default("Europe/Bratislava")
  currency        String           @default("EUR") @db.VarChar(3)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  roles           Role[]
  companies       Company[]
  contacts        Contact[]
  leads           Lead[]
  opportunities   Opportunity[]
  tasks           Task[]
  activities      Activity[]
  auditLogs       AuditLog[]
  leadSources     LeadSource[]
  automations     Automation[]
  notifications   Notification[]
  savedViews      SavedView[]
  meetings        Meeting[]
  invitations     UserInvitation[]
  importEvents    ImportEvent[]
  leadAiAnalyses  LeadAiAnalysis[]
  aiConversations AIConversation[]
  aiMessages      AIMessage[]
  aiActions       AIAction[]
  emailAccounts   EmailAccount[]
  emailThreads    EmailThread[]
  emailMessages   EmailMessage[]
  aiUsageEvents   AiUsageEvent[]
}

model User {
  id                  String           @id @default(uuid()) @db.Uuid
  workspaceId         String           @db.Uuid
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email               String
  name                String
  passwordHash        String?
  avatarUrl           String?
  status              UserStatus       @default(ACTIVE)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  roles               UserRole[]
  ownedCompanies      Company[]        @relation("CompanyOwner")
  ownedContacts       Contact[]        @relation("ContactOwner")
  assignedLeads       Lead[]           @relation("LeadOwner")
  ownedOpportunities  Opportunity[]    @relation("OpportunityOwner")
  assignedTasks       Task[]           @relation("TaskAssignee")
  createdTasks        Task[]           @relation("TaskCreator")
  auditLogs           AuditLog[]
  notifications       Notification[]
  createdMeetings     Meeting[]        @relation("MeetingCreator")
  receivedInvitations UserInvitation[] @relation("InvitedUser")
  createdInvitations  UserInvitation[] @relation("InvitationCreator")
  createdAiAnalyses   LeadAiAnalysis[] @relation("AiAnalysisCreator")
  approvedAiAnalyses  LeadAiAnalysis[] @relation("AiAnalysisApprover")
  aiConversations     AIConversation[]
  aiMessages          AIMessage[]
  aiActions           AIAction[]
  emailAccounts       EmailAccount[]
  aiUsageEvents       AiUsageEvent[]

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
}

model UserInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    @db.Uuid
  user        User      @relation("InvitedUser", fields: [userId], references: [id], onDelete: Cascade)
  createdById String    @db.Uuid
  createdBy   User      @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId, userId, expiresAt])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  workspaceId String           @db.Uuid
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  key         String
  description String?
  system      Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([workspaceId, key])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  description String
  roles       RolePermission[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Company {
  id                 String        @id @default(uuid()) @db.Uuid
  workspaceId        String        @db.Uuid
  workspace          Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerId            String?       @db.Uuid
  owner              User?         @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  name               String
  legalName          String?
  domain             String?
  website            String?
  registrationNumber String?
  country            String?       @db.VarChar(2)
  city               String?
  industry           String?
  lifecycleStatus    String        @default("PROSPECT")
  optedOut           Boolean       @default(false)
  lastContactedAt    DateTime?
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  contacts           Contact[]
  leads              Lead[]
  opportunities      Opportunity[]
  tasks              Task[]
  activities         Activity[]
  notes              Note[]
  meetings           Meeting[]
  emailThreads       EmailThread[]

  @@index([workspaceId, name])
  @@index([workspaceId, domain])
  @@index([workspaceId, registrationNumber])
}

model Contact {
  id              String        @id @default(uuid()) @db.Uuid
  workspaceId     String        @db.Uuid
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyId       String?       @db.Uuid
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerId         String?       @db.Uuid
  owner           User?         @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  firstName       String
  lastName        String
  email           String?
  phone           String?
  jobTitle        String?
  language        String?
  status          String        @default("NEW")
  optedOut        Boolean       @default(false)
  lastContactedAt DateTime?
  lastReplyAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  leads           Lead[]
  tasks           Task[]
  activities      Activity[]
  emailThreads    EmailThread[]

  @@index([workspaceId, email])
  @@index([workspaceId, lastName, firstName])
  @@index([workspaceId, ownerId, status])
}

model LeadSource {
  id                  String          @id @default(uuid()) @db.Uuid
  workspaceId         String          @db.Uuid
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                String
  key                 String
  sourceUrl           String?
  method              String
  active              Boolean         @default(false)
  cadenceMinutes      Int?
  legalNotes          String?
  approvalConfirmedAt DateTime?
  approvalConfirmedBy String?         @db.Uuid
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  runs                LeadSourceRun[]
  leads               Lead[]

  @@unique([workspaceId, key])
}

model LeadSourceRun {
  id             String          @id @default(uuid()) @db.Uuid
  sourceId       String          @db.Uuid
  source         LeadSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status         String
  collectedCount Int             @default(0)
  duplicateCount Int             @default(0)
  error          String?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  rawRecords     RawLeadRecord[]
}

model RawLeadRecord {
  id          String         @id @default(uuid()) @db.Uuid
  runId       String?        @db.Uuid
  run         LeadSourceRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  leadId      String?        @unique @db.Uuid
  lead        Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  externalId  String?
  payload     Json
  payloadHash String
  collectedAt DateTime       @default(now())

  @@index([payloadHash])
}

model Lead {
  id              String           @id @default(uuid()) @db.Uuid
  workspaceId     String           @db.Uuid
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId        String?          @db.Uuid
  source          LeadSource?      @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  companyId       String?          @db.Uuid
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId       String?          @db.Uuid
  contact         Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assigneeId      String?          @db.Uuid
  assignee        User?            @relation("LeadOwner", fields: [assigneeId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  originalText    String?
  sourceUrl       String?
  country         String?          @db.VarChar(2)
  language        String?
  serviceCategory String?
  budgetMinor     BigInt?
  budgetCurrency  String?          @db.VarChar(3)
  score           Int              @default(0)
  scoreReasons    Json             @default("[]")
  status          LeadStatus       @default(NEW)
  nextAction      String?
  nextActionAt    DateTime?
  retentionAt     DateTime?
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rawRecord       RawLeadRecord?
  importEvents    ImportEvent[]
  aiAnalyses      LeadAiAnalysis[]

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, score])
}

model LeadAiAnalysis {
  id                     String           @id @default(uuid()) @db.Uuid
  workspaceId            String           @db.Uuid
  workspace              Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId                 String           @db.Uuid
  lead                   Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  provider               String
  model                  String
  promptVersion          String
  status                 AiAnalysisStatus @default(QUEUED)
  summary                String?
  category               String?
  relevanceScore         Int?
  priority               String?
  detectedBudgetMin      Decimal?         @db.Decimal(18, 2)
  detectedBudgetMax      Decimal?         @db.Decimal(18, 2)
  detectedBudgetCurrency String?          @db.VarChar(3)
  technologies           Json             @default("[]")
  suggestedNextAction    String?
  riskFlags              Json             @default("[]")
  missingFields          Json             @default("[]")
  confidence             Float?
  inputHash              String
  inputCharacterCount    Int
  durationMs             Int?
  providerStartedAt      DateTime?
  createdByUserId        String           @db.Uuid
  createdByUser          User             @relation("AiAnalysisCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt              DateTime         @default(now())
  completedAt            DateTime?
  approvedAt             DateTime?
  approvedByUserId       String?          @db.Uuid
  approvedByUser         User?            @relation("AiAnalysisApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  ignoredAt              DateTime?
  errorCode              String?
  activeJobKey           String?          @unique

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, providerStartedAt])
  @@index([leadId, createdAt(sort: Desc)])
  @@index([leadId, inputHash, promptVersion, model])
  @@index([workspaceId, createdByUserId, providerStartedAt])
}

model ImportEvent {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @db.Uuid
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceName   String
  sourceType   String
  externalId   String?
  sourceUrl    String?
  dedupeKey    String
  canonicalKey String?
  status       String
  leadId       String?   @db.Uuid
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  metadata     Json      @default("{}")
  rawPayload   Json
  errorMessage String?
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?

  @@unique([workspaceId, canonicalKey])
  @@index([workspaceId, dedupeKey])
  @@index([workspaceId, sourceName, receivedAt(sort: Desc)])
  @@index([workspaceId, status, receivedAt(sort: Desc)])
}

model OpportunityStage {
  id            String        @id @default(uuid()) @db.Uuid
  workspaceId   String        @db.Uuid
  name          String
  key           String
  position      Int
  probability   Int
  terminal      Boolean       @default(false)
  opportunities Opportunity[]

  @@unique([workspaceId, key])
}

model Opportunity {
  id              String           @id @default(uuid()) @db.Uuid
  workspaceId     String           @db.Uuid
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyId       String           @db.Uuid
  company         Company          @relation(fields: [companyId], references: [id])
  ownerId         String?          @db.Uuid
  owner           User?            @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  stageId         String           @db.Uuid
  stage           OpportunityStage @relation(fields: [stageId], references: [id])
  name            String
  valueMinor      BigInt
  currency        String           @db.VarChar(3)
  probability     Int
  expectedCloseAt DateTime?
  nextStep        String?
  nextStepAt      DateTime?
  lostReason      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tasks           Task[]
  activities      Activity[]
  emailThreads    EmailThread[]

  @@index([workspaceId, stageId])
  @@index([workspaceId, ownerId])
}

model Task {
  id            String       @id @default(uuid()) @db.Uuid
  workspaceId   String       @db.Uuid
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assigneeId    String       @db.Uuid
  assignee      User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById   String       @db.Uuid
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id])
  companyId     String?      @db.Uuid
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId     String?      @db.Uuid
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId String?      @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title         String
  type          String
  status        TaskStatus   @default(OPEN)
  priority      Priority     @default(NORMAL)
  dueAt         DateTime
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workspaceId, assigneeId, status, dueAt])
}

model Activity {
  id            String       @id @default(uuid()) @db.Uuid
  workspaceId   String       @db.Uuid
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyId     String?      @db.Uuid
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId     String?      @db.Uuid
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId String?      @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  actorId       String?      @db.Uuid
  type          String
  title         String
  body          String?
  metadata      Json         @default("{}")
  occurredAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())

  @@index([workspaceId, occurredAt(sort: Desc)])
  @@index([companyId, occurredAt(sort: Desc)])
}

model Note {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @db.Uuid
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  authorId     String   @db.Uuid
  body         String
  confidential Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @db.Uuid
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  userId      String?     @db.Uuid
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  recordType  String
  recordId    String?
  oldValue    Json?
  newValue    Json?
  source      AuditSource
  requestId   String?
  sessionId   String?
  ipHash      String?
  createdAt   DateTime    @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, recordType, recordId])
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  body        String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}

model SavedView {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerId     String    @db.Uuid
  module      String
  name        String
  filters     Json
  columns     Json?
  shared      Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Automation {
  id          String          @id @default(uuid()) @db.Uuid
  workspaceId String          @db.Uuid
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  trigger     Json
  conditions  Json            @default("[]")
  actions     Json
  active      Boolean         @default(false)
  runs        AutomationRun[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model AutomationRun {
  id           String     @id @default(uuid()) @db.Uuid
  automationId String     @db.Uuid
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  eventId      String
  eventType    String
  status       String
  input        Json
  output       Json?
  error        String?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?

  @@unique([automationId, eventId])
  @@index([automationId, startedAt])
}

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String?   @db.Uuid
  type           String
  payload        Json
  status         JobStatus @default(PENDING)
  priority       Int       @default(0)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  runAt          DateTime  @default(now())
  lockedBy       String?
  lockedUntil    DateTime?
  idempotencyKey String?   @unique
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, runAt, priority])
}

// Provider-specific details remain JSON until their adapters are implemented.
model EmailAccount {
  id             String         @id @default(uuid()) @db.Uuid
  workspaceId    String         @db.Uuid
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId         String         @db.Uuid
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String
  address        String
  config         Json           @default("{}")
  active         Boolean        @default(false)
  syncMode       String         @default("CRM_MATCHED")
  syncWindowDays Int            @default(90)
  syncStatus     String         @default("IDLE")
  syncCursor     String?
  lastSyncedAt   DateTime?
  syncErrorCode  String?
  disconnectedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  threads        EmailThread[]
  messages       EmailMessage[]

  @@unique([workspaceId, address])
}

model EmailThread {
  id            String         @id @default(uuid()) @db.Uuid
  workspaceId   String         @db.Uuid
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId     String?        @db.Uuid
  account       EmailAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  companyId     String?        @db.Uuid
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId     String?        @db.Uuid
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId String?        @db.Uuid
  opportunity   Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  subject       String
  providerId    String?
  status        String         @default("OPEN")
  lastMessageAt DateTime?
  updatedAt     DateTime       @updatedAt
  messages      EmailMessage[]

  @@unique([workspaceId, providerId])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, contactId, lastMessageAt])
}

model EmailMessage {
  id             String        @id @default(uuid()) @db.Uuid
  workspaceId    String        @db.Uuid
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId      String?       @db.Uuid
  account        EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  threadId       String        @db.Uuid
  thread         EmailThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  providerId     String
  sender         String
  recipients     Json
  subject        String
  sanitizedBody  String?
  direction      String        @default("UNKNOWN")
  hasAttachments Boolean       @default(false)
  sentAt         DateTime

  @@unique([workspaceId, providerId])
}

model Call {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @db.Uuid
  contactId       String?  @db.Uuid
  outcome         String
  durationSeconds Int?
  occurredAt      DateTime
}

model Meeting {
  id            String            @id @default(uuid()) @db.Uuid
  workspaceId   String            @db.Uuid
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById   String            @db.Uuid
  createdBy     User              @relation("MeetingCreator", fields: [createdById], references: [id])
  companyId     String?           @db.Uuid
  company       Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  opportunityId String?           @db.Uuid
  title         String
  visibility    MeetingVisibility @default(WORKSPACE)
  eventType     String            @default("MEETING")
  allDay        Boolean           @default(false)
  startsAt      DateTime
  endsAt        DateTime
  location      String?
  meetingUrl    String?
  agenda        String?
  notes         String?
  result        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([workspaceId, startsAt])
}

enum MeetingVisibility {
  PRIVATE
  TEAM
  WORKSPACE
}

model Attachment {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  storageKey  String
  mimeType    String
  sizeBytes   Int
  sha256      String
  createdAt   DateTime @default(now())
}

model Tag {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid
  name        String

  @@unique([workspaceId, name])
}

model RecordTag {
  id         String @id @default(uuid()) @db.Uuid
  tagId      String @db.Uuid
  recordType String
  recordId   String

  @@unique([tagId, recordType, recordId])
}

model SuppressionRecord {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  kind        String
  valueHash   String
  reason      String
  createdAt   DateTime @default(now())

  @@unique([workspaceId, kind, valueHash])
}

model AIConversation {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @db.Uuid
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String      @db.Uuid
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  contextType String?
  contextId   String?
  updatedAt   DateTime    @updatedAt
  createdAt   DateTime    @default(now())
  messages    AIMessage[]
  actions     AIAction[]

  @@index([workspaceId, userId, updatedAt])
}

model AIAction {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspaceId    String         @db.Uuid
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId         String         @db.Uuid
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool           String
  input          Json
  preview        Json
  status         String
  resultType     String?
  resultId       String?
  confirmedAt    DateTime?
  createdAt      DateTime       @default(now())

  @@index([workspaceId, userId, status])
}

model AIMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspaceId    String         @db.Uuid
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId         String         @db.Uuid
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  content        String
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([workspaceId, userId, createdAt])
}

model AiUsageEvent {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  operation   String
  provider    String
  model       String
  startedAt   DateTime  @default(now())

  @@index([workspaceId, startedAt])
  @@index([workspaceId, userId, startedAt])
}

model ImportJob {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  userId      String   @db.Uuid
  status      String
  counts      Json     @default("{}")
  createdAt   DateTime @default(now())
}

model ExportJob {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  userId      String   @db.Uuid
  status      String
  filters     Json
  createdAt   DateTime @default(now())
}

model DuplicateCandidate {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  recordType  String
  leftId      String
  rightId     String
  score       Int
  evidence    Json
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())

  @@unique([workspaceId, recordType, leftId, rightId])
}
